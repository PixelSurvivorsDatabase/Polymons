SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-supabase-secret-key
PLAY_TICKET_SECRET=replace-with-at-least-32-random-characters

# Production deploys should use the public site URL.
WEB_ORIGIN=https://pixelsurvivorsdatabase.github.io
PORT=10000

# Local development:
# WEB_ORIGIN=http://localhost:5173
# VITE_POLYMONS_API_URL=http://localhost:10000

# Optional: host PolyCode checkpoints outside Supabase Storage to avoid
# burning Supabase egress on Render restarts. GitHub Release asset URLs work.
# POLYCODE_13M_CHECKPOINT_URL=https://github.com/PixelSurvivorsDatabase/Polymons/releases/latest/download/polycode-13m-checkpoint-final.pt
# POLYCODE_28M_CHECKPOINT_URL=https://github.com/PixelSurvivorsDatabase/Polymons/releases/latest/download/polycode-28m-checkpoint-latest.pt
