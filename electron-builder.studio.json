{
  "appId": "com.polymons.studio",
  "productName": "Poly Studio",
  "asar": true,
  "compression": "normal",
  "extraMetadata": {
    "main": "studio-dist/main/main.js",
    "productName": "Poly Studio"
  },
  "directories": {
    "output": "studio-release"
  },
  "files": [
    "studio-dist/**/*",
    "package.json",
    "!node_modules/**/*"
  ],
  "win": {
    "target": [
      "portable"
    ],
    "icon": "assets/studio/poly-studio-logo-dark.png",
    "artifactName": "PolyStudio.exe"
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "assets/studio/poly-studio-logo-dark.png",
    "category": "public.app-category.developer-tools",
    "hardenedRuntime": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.inherit.plist",
    "artifactName": "PolyStudio-mac-${arch}.${ext}"
  }
}
