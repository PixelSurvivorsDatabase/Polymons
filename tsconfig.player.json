{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "player-dist/main",
    "rootDir": "player/main",
    "sourceMap": true,
    "noEmitOnError": true,
    "types": ["node", "electron"]
  },
  "include": ["player/main/**/*.ts"]
}
