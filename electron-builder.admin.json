{
  "appId": "com.polymons.admin",
  "productName": "Poly Admin",
  "asar": true,
  "extraMetadata": {
    "main": "admin-dist/main/main.js",
    "productName": "Poly Admin"
  },
  "directories": {
    "output": "admin-release"
  },
  "files": [
    "admin-dist/**/*",
    "package.json",
    "!node_modules/**/*"
  ],
  "win": {
    "target": [
      "portable"
    ],
    "icon": "assets/polymons-logo.png",
    "artifactName": "PolyAdmin.exe"
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "assets/polymons-logo.png",
    "category": "public.app-category.developer-tools",
    "hardenedRuntime": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.inherit.plist",
    "artifactName": "PolyAdmin-mac-${arch}.${ext}"
  }
}
