{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "server-dist",
    "rootDir": "server",
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["server/**/*.ts"]
}
