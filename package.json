{
  "name": "polymons",
  "productName": "Polymons Player",
  "description": "The Polymons website, game server, and portable Windows Player.",
  "author": "Polymons",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "player-dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:build": "tsc -p tsconfig.server.json",
    "server:start": "npm run server:build && npm run server:serve",
    "server:serve": "node server-dist/index.js",
    "server:dev": "tsx watch server/index.ts",
    "server:test": "tsx --test server/server.test.ts",
    "runtime:test": "tsx --test src/game/polyProject.test.ts",
    "player:main": "tsc -p tsconfig.player.json && node scripts/copy-player-assets.mjs",
    "player:renderer": "tsc -p tsconfig.player-renderer.json && vite build --config vite.player.config.ts",
    "player:build": "npm run player:main && npm run player:renderer",
    "player:package": "npm run player:build && electron-builder --win portable",
    "studio:main": "tsc -p tsconfig.studio.json && node scripts/copy-studio-assets.mjs",
    "studio:renderer": "tsc -p tsconfig.studio-renderer.json && vite build --config vite.studio.config.ts",
    "studio:build": "npm run studio:main && npm run studio:renderer",
    "studio:package": "npm run studio:build && electron-builder --config electron-builder.studio.json --win portable",
    "supabase:push": "supabase db push --linked",
    "supabase:lint": "supabase db lint --linked --schema public,private --level warning --fail-on error",
    "supabase:advisors": "supabase db advisors --linked --type security --level warn --fail-on error"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "@supabase/supabase-js": "^2.108.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "three": "^0.184.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "supabase": "^2.106.0",
    "tsx": "^4.22.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.polymons.player",
    "productName": "Polymons Player",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "player-dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/polymons-logo.png",
      "artifactName": "PolymonsPlayer.exe"
    }
  }
}
